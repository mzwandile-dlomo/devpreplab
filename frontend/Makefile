# Frontend Makefile for DevPrepLab

.PHONY: help install dev build lint

help:
	@echo "Frontend Makefile"
	@echo ""
	@echo "Usage:"
	@echo "  make help          Show this help message"
	@echo "  make install       Install frontend dependencies"
	@echo "  make dev           Run the frontend dev server"
	@echo "  make build         Build the frontend application"
	@echo "  make lint          Lint the frontend code"

install:
	npm install

dev:
	npm run dev

build:
	npm run build

lint:
	npm run lint
