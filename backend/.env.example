# Production Database (Supabase PostgreSQL)
# Note: URL-encode special characters in password (e.g., * becomes %2A, ? becomes %3F)
DATABASE_URL=postgresql://user:password@host:5432/database

# Production Redis (Upstash)
# Use rediss:// for TLS connection
REDIS_URL=rediss://default:password@host:6379

# For test database (optional)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_SERVER=your_host
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_DB_TEST=test_devpreplab

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=generate-a-secure-random-key-here

# Environment
ENVIRONMENT=production
TESTING=False
